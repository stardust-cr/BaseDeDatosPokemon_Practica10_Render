@model Practica_10.Pokemon_Movimiento

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Pokemon_Movimiento</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Pokemon)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Pokemon.NumeroPokemon)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Movimiento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Movimiento.Nombre)
        </dd>
    </dl>
</div>
<div>
    @Html.ActionLink("Edit", "Edit", new { Model?.NumPokemon,Model?.NumMovimiento}) |
    <a asp-action="Index">Back to List</a>
</div>
